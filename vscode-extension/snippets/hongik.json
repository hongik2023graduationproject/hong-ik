{
    "출력": {
        "prefix": "출력",
        "body": "출력(${1:값})",
        "description": "값을 콘솔에 출력합니다"
    },
    "변수 선언 (정수)": {
        "prefix": "정수",
        "body": "정수 ${1:변수명} = ${2:0}",
        "description": "정수 변수를 선언합니다"
    },
    "변수 선언 (실수)": {
        "prefix": "실수",
        "body": "실수 ${1:변수명} = ${2:0.0}",
        "description": "실수 변수를 선언합니다"
    },
    "변수 선언 (문자)": {
        "prefix": "문자",
        "body": "문자 ${1:변수명} = \"${2:}\"",
        "description": "문자열 변수를 선언합니다"
    },
    "변수 선언 (배열)": {
        "prefix": "배열",
        "body": "배열 ${1:변수명} = [${2:}]",
        "description": "배열 변수를 선언합니다"
    },
    "변수 선언 (사전)": {
        "prefix": "사전",
        "body": "사전 ${1:변수명} = {${2:}}",
        "description": "사전(딕셔너리) 변수를 선언합니다"
    },
    "조건문": {
        "prefix": "만약",
        "body": [
            "만약 ${1:조건} 라면:",
            "    ${2:// 참일 때}",
            "아니면:",
            "    ${3:// 거짓일 때}"
        ],
        "description": "만약/아니면 조건문"
    },
    "조건문 (아니면 없이)": {
        "prefix": "만약라면",
        "body": [
            "만약 ${1:조건} 라면:",
            "    ${2:// 참일 때}"
        ],
        "description": "만약 조건문 (아니면 없이)"
    },
    "함수 정의": {
        "prefix": "함수",
        "body": [
            "함수: [${1:정수}]${2:매개변수} ${3:함수명} -> [${4:정수}]:",
            "    ${5:리턴 값}"
        ],
        "description": "함수를 정의합니다"
    },
    "함수 정의 (매개변수 없음)": {
        "prefix": "함수없",
        "body": [
            "함수 ${1:함수명} -> [${2:정수}]:",
            "    ${3:리턴 값}"
        ],
        "description": "매개변수 없는 함수를 정의합니다"
    },
    "함수 호출": {
        "prefix": "호출",
        "body": ":(${1:인자})${2:함수명}",
        "description": "함수를 호출합니다"
    },
    "반복문 (동안)": {
        "prefix": "동안",
        "body": [
            "반복 ${1:조건} 동안:",
            "    ${2:// 반복 내용}"
        ],
        "description": "조건 반복문 (while)"
    },
    "반복문 (각각)": {
        "prefix": "각각",
        "body": [
            "각각 ${1:항목} 에서 ${2:배열}:",
            "    ${3:// 반복 내용}"
        ],
        "description": "순회 반복문 (for-each)"
    },
    "반복문 (범위)": {
        "prefix": "부터",
        "body": [
            "각각 ${1:i} 부터 ${2:0} 까지 ${3:10}:",
            "    ${4:// 반복 내용}"
        ],
        "description": "범위 반복문 (for range)"
    },
    "클래스 정의": {
        "prefix": "클래스",
        "body": [
            "클래스 ${1:클래스명}:",
            "    생성(${2:매개변수}):",
            "        자기.${3:속성} = ${2:매개변수}",
            "",
            "    함수 ${4:메서드명}():",
            "        ${5:// 메서드 내용}"
        ],
        "description": "클래스를 정의합니다"
    },
    "비교문 (패턴 매칭)": {
        "prefix": "비교",
        "body": [
            "비교 ${1:값}:",
            "    경우 ${2:패턴1}:",
            "        ${3:// 처리}",
            "    경우 ${4:패턴2}:",
            "        ${5:// 처리}",
            "    기본:",
            "        ${6:// 기본 처리}"
        ],
        "description": "패턴 매칭 비교문"
    },
    "시도/실패": {
        "prefix": "시도",
        "body": [
            "시도:",
            "    ${1:// 실행할 코드}",
            "실패 ${2:에러}:",
            "    ${3:출력(에러)}"
        ],
        "description": "예외 처리 시도/실패 블록"
    },
    "시도/실패/마침내": {
        "prefix": "시도마침",
        "body": [
            "시도:",
            "    ${1:// 실행할 코드}",
            "실패 ${2:에러}:",
            "    ${3:출력(에러)}",
            "마침내:",
            "    ${4:// 항상 실행}"
        ],
        "description": "예외 처리 시도/실패/마침내 블록"
    },
    "매핑": {
        "prefix": "매핑",
        "body": "매핑(${1:배열}, 함수: [${2:정수}]${3:x} -> ${4:x * 2})",
        "description": "배열에 함수를 매핑합니다 (map)"
    },
    "걸러내기": {
        "prefix": "걸러내기",
        "body": "걸러내기(${1:배열}, 함수: [${2:정수}]${3:x} -> ${4:x > 0})",
        "description": "배열에서 조건에 맞는 요소만 걸러냅니다 (filter)"
    },
    "파일 읽기/쓰기": {
        "prefix": "파일",
        "body": [
            "문자 ${1:내용} = 파일읽기(\"${2:파일경로}\")",
            "파일쓰기(\"${3:파일경로}\", ${4:내용})"
        ],
        "description": "파일 읽기와 쓰기"
    },
    "JSON 파싱": {
        "prefix": "json",
        "body": "JSON_파싱(${1:문자열})",
        "description": "JSON 문자열을 객체로 파싱합니다"
    },
    "생산 (제너레이터)": {
        "prefix": "생산",
        "body": "생산 ${1:값}",
        "description": "제너레이터에서 값을 생산합니다 (yield)"
    }
}
