{
    "name": "hongik-language",
    "displayName": "Hong-Ik Language",
    "description": "Syntax highlighting and code snippets for the Hong-Ik Korean programming language (.hik files)",
    "version": "0.2.0",
    "publisher": "hong-ik",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets"
    ],
    "contributes": {
        "languages": [
            {
                "id": "hongik",
                "aliases": [
                    "Hong-Ik",
                    "hongik",
                    "홍익"
                ],
                "extensions": [
                    ".hik"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/hongik-light.png",
                    "dark": "./icons/hongik-dark.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "hongik",
                "scopeName": "source.hongik",
                "path": "./syntaxes/hongik.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "hongik",
                "path": "./snippets/hongik.json"
            }
        ]
    }
}
