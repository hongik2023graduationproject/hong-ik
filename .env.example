# hong-ik 빌드/실행 환경 변수 예시
# hong-ik 인터프리터 자체는 환경 변수 의존성이 적다. 빌드는 CMake로, 실행은 인자로 받는다.
# 본 파일은 CI/Docker 빌드 환경에서 자주 쓰이는 변수만 기록.

# ────────────────────────────────────
# 빌드
# ────────────────────────────────────

# CMake 빌드 타입 (Debug | Release | RelWithDebInfo)
CMAKE_BUILD_TYPE=Release

# sanitizer 빌드 시 (개발 중에만): -DENABLE_SANITIZERS=ON
# 사용 예: cmake -B build -DCMAKE_BUILD_TYPE=Debug -DENABLE_SANITIZERS=ON

# ────────────────────────────────────
# WASM 크로스 빌드 (Emscripten)
# ────────────────────────────────────

# emsdk 설치 위치. Dockerfile/CI에서만 필요.
EMSDK=/opt/emsdk

# ────────────────────────────────────
# 인터프리터 실행 시
# ────────────────────────────────────

# 환경 변수 의존 없음. 사용법:
#   ./HongIk <filename.hik>     파일 실행
#   ./HongIk                    REPL 모드
#   ./HongIk --vm <filename>    VM 백엔드 사용 (기본은 evaluator)
